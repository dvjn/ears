{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ears",
  "version": "0.1.0",
  "identifier": "dev.dvjn.ears",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "ears",
        "width": 420,
        "height": 460,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false
      },
      {
        "label": "live",
        "url": "live.html",
        "title": "ears - live",
        "width": 720,
        "height": 200,
        "resizable": false,
        "visible": false,
        "focus": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "shadow": false,
        "transparent": true
      }
    ],
    "withGlobalTauri": true,
    "enableGTKAppId": true
  }
}
