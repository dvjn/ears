{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ears",
  "version": "0.1.0",
  "identifier": "dev.dvjn.ears",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "publisher": "dvjn",
    "copyright": "Copyright © 2026 dvjn",
    "shortDescription": "voice dictation app",
    "longDescription": "a voice dictation app. press a shortcut, speak, and ears transcribes what you said using an openai-compatible api.",
    "homepage": "https://github.com/dvjn/ears",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libasound2"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost",
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "ears",
        "width": 420,
        "height": 460,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false
      },
      {
        "label": "live",
        "url": "live.html",
        "title": "ears - live",
        "width": 720,
        "height": 200,
        "resizable": false,
        "visible": false,
        "focus": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": false,
        "shadow": false,
        "transparent": true
      }
    ],
    "withGlobalTauri": true,
    "enableGTKAppId": true
  }
}
