{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ears",
  "version": "0.1.0",
  "identifier": "dev.dvjn.ears",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "ears",
        "width": 420,
        "height": 460,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false
      }
    ],
    "withGlobalTauri": true,
    "enableGTKAppId": true
  }
}
